<?xml version="1.0" encoding="utf-8"?>

<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 rescap">

  <Identity
    Name="ZunaidFarouque.CmdPalSearchHub"
    Publisher="CN=Zunaid Farouque"
    Version="0.0.1.0" />
  <!-- Publisher must match the Subject of the PFX used to sign the MSIX (see docs/Signing.md). -->

  <Properties>
    <DisplayName>CmdPal Search Hub</DisplayName>
    <PublisherDisplayName>Zunaid Farouque</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.19041.0" MaxVersionTested="10.0.19041.0" />
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.19041.0" />
  </Dependencies>

  <Resources>
    <Resource Language="x-generate"/>
  </Resources>

  <Applications>
    <Application Id="App"
      Executable="$targetnametoken$.exe"
      EntryPoint="$targetentrypoint$">
        <uap:VisualElements
        DisplayName="CmdPal Search Hub"
        Description="Search the web from Windows Command Palette: one hub for many engines (Google, YouTube, GitHub, Bing, and more), optional short abbreviations like &quot;g &quot; or &quot;yt &quot;, and your own URL templates. Turn on query suggestions for Google and YouTube, and optional in-palette previews—configure YouTube Data API and Google Programmable Search keys for rich results, or open a normal search for everything else."
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
      <Extensions>
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:ExeServer Executable="CmdPal_UniversalSearchHub_Extension.exe" Arguments="-RegisterProcessAsComServer" DisplayName="CmdPal Search Hub">
              <com:Class Id="d65cba02-40e6-47c9-8e71-98b7c5a15887" DisplayName="CmdPal Search Hub" />
            </com:ExeServer>
          </com:ComServer>
        </com:Extension>
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension Name="com.microsoft.commandpalette"
            Id="ID"
            PublicFolder="Public"
            DisplayName="CmdPal Search Hub"
            Description="Multi-engine web search in Command Palette—built-in and custom engines, abbreviation + query, optional Google/YouTube suggestions, and in-palette previews with API keys.">
            <uap3:Properties>
              <CmdPalProvider>
                <Activation>
                  <CreateInstance ClassId="d65cba02-40e6-47c9-8e71-98b7c5a15887" />
                </Activation>
                <SupportedInterfaces>
                  <Commands/>
                  <Settings/>
                </SupportedInterfaces>
              </CmdPalProvider>
            </uap3:Properties>
          </uap3:AppExtension>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
